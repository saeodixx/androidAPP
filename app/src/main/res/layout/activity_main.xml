<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">



    <!-- Z-Index 기반 오버레이 처리를 위해 최상위 루트 뷰를 DrawerLayout으로 지정합니다. -->
    <androidx.drawerlayout.widget.DrawerLayout
        xmlns:android="http://schemas.android.com/apk/res/android"
        xmlns:app="http://schemas.android.com/apk/res-auto"
        android:id="@+id/drawerLayout"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <!-- [첫 번째 자식 뷰] 본문 (Main Content) 영역: 화면 구조상 가장 바닥(Bottom)에 렌더링됩니다. -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <androidx.appcompat.widget.Toolbar
                android:id="@+id/myToolbar"
                android:layout_width="match_parent"
                android:layout_height="?attr/actionBarSize"
                android:background="?attr/colorPrimary"
                app:titleTextColor="@android:color/white"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:text="좌측 가장자리를 스와이프하거나 햄버거 아이콘을 누르세요." />
        </LinearLayout>

        <!-- [두 번째 자식 뷰] 서랍 (Drawer) 영역: 평소에는 화면 바깥에 숨겨져 있다가 제스처에 의해 본문 위를 덮으며 나타납니다. -->
        <!-- 반드시 layout_gravity를 명시하여 서랍의 출현 방향을 시스템에 알립니다. (start = 좌측에서 우측으로) -->
        <com.google.android.material.navigation.NavigationView
            android:id="@+id/navigationView"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_gravity="start"
            app:menu="@menu/drawer_menu" />

    </androidx.drawerlayout.widget.DrawerLayout>
</LinearLayout>